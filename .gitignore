# Secrets / personal config — never commit (copy from the .sample instead)
*vault*
group_vars/*secret*
group_vars/all.yml
*.pem
# Custom MOTD / host banner content — per-deployment (copy from the .sample.html)
roles/l4d2_fleet/files/*.local.html
# Ansible retry/cache
*.retry
.ansible/
# Local game files (downloaded at provision time)
left4dead2/

# Python bytecode
__pycache__/
*.pyc
